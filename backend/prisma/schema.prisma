generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Paciente {
  id           Int      @id @default(autoincrement())
  nombre       String
  email        String   @unique
  telefono     String
  edad         Int
  diagnostico  String
  createdAt    DateTime @default(now())
}
